# Copy this file to .env for local development.
# Do not put real API keys or secrets in committed files.

# Server
PORT=3000
TRUST_PROXY_HEADERS=false
SSE_HEARTBEAT_MS=15000
SERVER_MAX_CONNECTIONS=200
SERVER_REQUEST_TIMEOUT_MS=0
SERVER_HEADERS_TIMEOUT_MS=60000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000

# Request limits
MAX_IMAGES_PER_TURN=4
MAX_IMAGE_BYTES=5242880
RECENT_CONTEXT_TURN_LIMIT=10
# MAX_JSON_BODY_BYTES=

# OpenAI models: gpt-5-mini, gpt-5-nano
OPENAI_API_KEY=
OPENAI_RESPONSES_URL=https://api.openai.com/v1/responses
OPENAI_PERSONA_GENERATION_TOKENS=4000
OPENAI_STREAM_TOKENS=4000
OPENAI_REASONING_EFFORT=minimal

# Local Gemma runner
# GEMMA_PYTHON=/path/to/python3
# GEMMA_MODEL_PATH=/path/to/gemma-4-E2B_q4_0-it.gguf
# GEMMA_MM_PROJECTOR_PATH=/path/to/mmproj-google_gemma-4-E2B-it-f16.gguf
# GEMMA_CLIP_MODEL_PATH=/path/to/mmproj-google_gemma-4-E2B-it-f16.gguf
GEMMA_DISABLE_VISION=false
GEMMA_REQUIRE_VISION_FOR_IMAGES=true
GEMMA_MM_PROJECTOR_USE_GPU=false

# Gemma runtime tuning
GEMMA_N_CTX=131072
GEMMA_THREADS=2
GEMMA_N_BATCH=64
GEMMA_N_GPU_LAYERS=0
GEMMA_OFFLOAD_KQV=false

# Gemma generation tuning
GEMMA_PERSONA_GENERATION_TOKENS=700
GEMMA_STREAM_TOKENS=32000
GEMMA_TEMPERATURE=1
GEMMA_TOP_P=0.95
GEMMA_TOP_K=64
GEMMA_REPEAT_PENALTY=1.05

# Local Gemma request scheduling
MAX_CONCURRENT_STREAMS=100
PER_IP_MIN_TURN_INTERVAL_MS=3000
PER_IP_MAX_QUEUED_TURNS=5
